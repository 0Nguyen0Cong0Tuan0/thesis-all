# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
*.swp
.vscode/
.idea/

# Secrets
.env
*.pem
*.key

# Build / cache
*.log
build/
dist/

# Training outputs — large & regenerable. Keep small metrics/config (JSON, cfg_args)
# and analysis artifacts; exclude model checkpoints and render dumps.
results/output/**/point_cloud/
results/output/**/test/
results/output/**/specular/
results/output/**/input.ply
# Run-output folders carry version suffixes (spec_fastgs_output_v2.3-..., __v2.4-..._1),
# so match the prefix, not just the bare name. Also the training "output/" dir.
spec_fastgs_output*/
spec-fastgs/output/
output/

# 3DGS checkpoints / point clouds are always regenerable and often >100MB
# (GitHub's hard push limit) — never commit them.
*.ply
*.pt